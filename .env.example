# Copy to .env and fill in values
# cp .env.example .env

# AWS credentials — leave commented to use ~/.aws/credentials or an IAM instance role
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Default region shown on page load
AWS_DEFAULT_REGION=us-east-1

# Server binding
SPARKLE_HOST=0.0.0.0
SPARKLE_PORT=8000

# Set to 1 during frontend dev (enables CORS for Vite on :5173)
SPARKLE_DEV=
